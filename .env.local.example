# ============================================================
# IGNITE AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# Add ALL of these to your Vercel project environment variables.
# ============================================================

# --- Google Sheets ---
# Create a Google Service Account, share your Sheet with its email,
# and paste the credentials below.
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# --- Notion ---
# Create a Notion Integration at https://www.notion.so/my-integrations
# Share your database with the integration, then paste below.
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=your_notion_database_id_here

# --- Email (Gmail SMTP) ---
# Use a Gmail address. Generate an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=caibenjamin500@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# --- Notification Recipients (comma-separated) ---
NOTIFICATION_EMAILS=caibenjamin500@gmail.com,mavis@igniteaiagents.com
